# =============================================================================
# Astarlabshub — Environment Configuration Example
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# All settings listed here match app/config.py.
# Lines starting with '#' are comments; uncommented lines with '=' are active.
# =============================================================================

# ---------------------------------------------------------------------------
# Database & Persistence
# ---------------------------------------------------------------------------

# SQLAlchemy connection string.
# SQLite:  sqlite:///./data/astarlabshub.db
# PostgreSQL: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./data/astarlabshub.db

# SQLAlchemy pool size (number of connections to keep in the pool).
DB_POOL_SIZE=5

# Maximum overflow connections beyond pool_size.
DB_POOL_MAX_OVERFLOW=10

# Enable SQLAlchemy echo logging (1 = on, 0 = off).
DB_ECHO=0

# Set to 1 to force SQLAlchemy ORM mode (otherwise raw SQL may be used).
USE_SQLALCHEMY=0

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Web / FastAPI
# ---------------------------------------------------------------------------

# Host address to bind the FastAPI server.
HOST=0.0.0.0

# Port to bind the FastAPI server.
PORT=8000

# Comma-separated list of allowed CORS origins (* allows all).
CORS_ORIGINS=*

# Secret key for session signing / CSRF protection.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=default-secret-key-for-development

# Enable debug mode (1 = on, 0 = off).
DEBUG=0

# ---------------------------------------------------------------------------
# LLM / AI
# ---------------------------------------------------------------------------

# LLM provider: anthropic, openai, google, etc.
LLM_PROVIDER=anthropic

# Model name (provider-specific).
# Anthropic example: claude-sonnet-4-20241022
# OpenAI example:    gpt-4o
LLM_MODEL=claude-sonnet-4-20241022

# Temperature setting for LLM completions (0.0 – 1.0).
LLM_TEMPERATURE=0.7

# Maximum tokens per LLM response.
LLM_MAX_TOKENS=4096

# Maximum number of concurrent LLM calls.
MAX_CONCURRENT_LLM=5

# ---------------------------------------------------------------------------
# Task Queue
# ---------------------------------------------------------------------------

# Default timeout (in seconds) for individual tasks.
TASK_TIMEOUT=300

# Minimum thread pool size for the task queue.
TASK_QUEUE_THREAD_POOL_MIN=2

# Maximum thread pool size for the task queue.
TASK_QUEUE_THREAD_POOL_MAX=10

# Number of tasks to prefetch from the queue.
TASK_QUEUE_PREFETCH_COUNT=5

# ---------------------------------------------------------------------------
# Composio Integration
# ---------------------------------------------------------------------------

# API key for Composio (https://composio.dev).
# Required for agent tool execution. Keep this secret!
COMPOSIO_API_KEY=

# Base URL for the Composio API.
COMPOSIO_BASE_URL=https://api.composio.dev

# Rate limit: maximum API calls per minute.
COMPOSIO_RATE_LIMIT_PER_MIN=60

# Rate limit: maximum API calls per second.
COMPOSIO_RATE_LIMIT_PER_SEC=10

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

# Storage backend: local, s3, gcs, etc.
STORAGE_BACKEND=local

# Directory where the built frontend is served from.
FRONTEND_DIR=./frontend

# ---------------------------------------------------------------------------
# Environment Metadata
# ---------------------------------------------------------------------------

# Optional prefix applied to all env-var lookups (useful in multi-tenant deployments).
ENV_PREFIX=